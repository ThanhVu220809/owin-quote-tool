# Supabase — COPY file này thành `.env` và điền giá trị thật.
# `.env` đã .gitignore — KHÔNG commit giá trị thật.
# anon key là PUBLIC (nhúng bundle client là bình thường). KHÔNG bao giờ đưa service_role key xuống client.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
