# Cấu hình Google Sync — COPY file này thành `.env` và điền giá trị thật.
# `.env` đã được .gitignore — KHÔNG commit giá trị thật.
#
# ⚠️ Lưu ý kiến trúc (BR-7): client_secret của Google KHÔNG nằm ở đây và KHÔNG bao giờ
#    xuống front-end — nó chỉ ở Script Properties của Apps Script.
#    3 biến dưới đây BẮT BUỘC nhúng vào bundle client (client phải gửi chúng cho backend):
#      - CLIENT_ID: public, lộ là bình thường.
#      - BACKEND_URL: public (URL Apps Script /exec).
#      - SHARED_SECRET: chỉ để chặn người lạ gọi backend; vì client phải gửi nên nó
#        nằm trong bundle — chấp nhận theo thiết kế. Việc cần là KHÔNG commit nó vào git.

VITE_GOOGLE_CLIENT_ID=706495406475-26nocn7kkvog10rtcvhkn098tv8mgns5.apps.googleusercontent.com
VITE_BACKEND_URL=https://script.google.com/macros/s/AKfycbwDfxe5miFXnnv5EzDlBO64hVi3xf9x0cHy-oEsmWSWwa12Tne0zHzsq94Bs44UT_pklA/exec
VITE_SHARED_SECRET=123456788
